# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# ── Mini App (build-time, read via import.meta.env; set these in Cloudflare Pages) ──
# Bot/app deep link shown on the outside-Telegram fallback page (QR + "Open in Telegram").
VITE_BOT_URL=https://t.me/your_storefront_bot/store
# TON testnet receiving address for payments (a real 48-char testnet address).
VITE_TON_RECIPIENT_TESTNET=0Q____________________________________________
# Optional toncenter testnet API key — raises the indexer rate limit so payment
# confirmation is reliable (no "Confirming…" stalls). Absent → unkeyed public endpoint.
VITE_TONCENTER_API_KEY=

# ── Optional bot launcher (runtime; long-polling /start process, e.g. via pm2) ──
# @BotFather token.
BOT_TOKEN=123456:replace-with-your-botfather-token
# The deployed Mini App URL the bot's launch button opens.
WEB_APP_URL=https://your-app.pages.dev
